# Copier vers .env et adapter.

# --- Recommandé en prod (hébergeur du backoffice) ---
# URL du backend Nest (secret côté serveur Nuxt). Le navigateur appelle /__nest/... sur le même domaine.
# NUXT_API_BACKEND=https://votre-api.onrender.com

# --- Option : appels directs navigateur → Nest (CORS doit autoriser l’origine du backoffice) ---
# NUXT_PUBLIC_API_BASE=https://votre-api.onrender.com
